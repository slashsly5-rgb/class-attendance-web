# Supabase Configuration
# NEXT_PUBLIC_ prefix is required for client-side access in Next.js
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key for server-side admin operations (keep secret!)
# WARNING: Never use NEXT_PUBLIC_ prefix for service role key - it must remain server-side only
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Instructions:
# 1. Copy this file to .env.local (which is gitignored)
# 2. Replace placeholder values with actual credentials from your Supabase project
# 3. The .env.local file will be automatically loaded by Next.js during development
